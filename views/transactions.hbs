<div class="app-layout">
  {{> sidebar}}
  <div class="main-content">
    {{> topbar}}
    <div class="page-content">
      <div class="card">
        <div class="card-header">
          <h3><i class="fas fa-exchange-alt"></i> Giao dịch</h3>
          <div class="card-header-actions">
            <button class="btn btn-success btn-sm" onclick="openScanner()">
              <i class="fas fa-camera"></i> Quét bill
            </button>
            <button class="btn btn-primary btn-sm" onclick="openTransactionModal()">
              <i class="fas fa-plus"></i> Thêm giao dịch
            </button>
          </div>
        </div>

        <!-- Filters -->
        <div class="filter-bar">
          <select class="form-input" id="filterType" onchange="loadTransactions()">
            <option value="">Tất cả loại</option>
            <option value="INCOME">Thu nhập</option>
            <option value="EXPENSE">Chi tiêu</option>
          </select>
          <select class="form-input" id="filterCategory" onchange="loadTransactions()">
            <option value="">Tất cả danh mục</option>
          </select>
          <input type="date" class="form-input" id="filterStartDate" onchange="loadTransactions()">
          <input type="date" class="form-input" id="filterEndDate" onchange="loadTransactions()">
          <button class="btn btn-ghost btn-sm" onclick="clearFilters()">
            <i class="fas fa-times"></i> Xóa bộ lọc
          </button>
        </div>

        <!-- Table -->
        <div class="card-body">
          <table class="data-table">
            <thead>
              <tr>
                <th>Danh mục</th>
                <th>Mô tả</th>
                <th>Ngày</th>
                <th>Loại</th>
                <th>Số tiền</th>
                <th>Hành động</th>
              </tr>
            </thead>
            <tbody id="transactionsTable">
              <tr><td colspan="6"><div class="loading-spinner"><div class="spinner"></div></div></td></tr>
            </tbody>
          </table>
        </div>

        <!-- Pagination -->
        <div class="pagination" id="transactionsPagination" style="display:none">
          <span class="pagination-info" id="paginationInfo"></span>
          <div class="pagination-controls" id="paginationControls"></div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Transaction Modal -->
<div class="modal-overlay" id="transactionModal" style="display:none">
  <div class="modal">
    <div class="modal-header">
      <h2 id="transactionModalTitle">Thêm giao dịch</h2>
      <button class="modal-close" onclick="closeTransactionModal()"><i class="fas fa-times"></i></button>
    </div>
    <div class="modal-body">
      <form id="transactionForm" onsubmit="saveTransaction(event)">
        <input type="hidden" id="txId">
        <div class="form-row">
          <div class="form-group">
            <label class="form-label">Loại</label>
            <select class="form-input" id="txType" required>
              <option value="EXPENSE">Chi tiêu</option>
              <option value="INCOME">Thu nhập</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label">Số tiền</label>
            <input type="number" class="form-input" id="txAmount" placeholder="0" min="0" step="1000" required>
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">Danh mục</label>
          <select class="form-input" id="txCategory" required>
            <option value="">Chọn danh mục</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">Ngày giao dịch</label>
          <input type="date" class="form-input" id="txDate" required>
        </div>
        <div class="form-group">
          <label class="form-label">Mô tả</label>
          <input type="text" class="form-input" id="txDescription" placeholder="Ghi chú (tùy chọn)">
        </div>
      </form>
    </div>
    <div class="modal-footer">
      <button class="btn btn-outline" onclick="closeTransactionModal()">Hủy</button>
      <button class="btn btn-primary" onclick="document.getElementById('transactionForm').requestSubmit()">
        <i class="fas fa-save"></i> Lưu
      </button>
    </div>
  </div>
</div>
